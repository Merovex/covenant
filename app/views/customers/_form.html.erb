<%# locals: (customer:) %>
<%= render "shared/error_summary", model: customer %>

<%= form_with model: customer do |f| %>
  <div class="field">
    <%= f.label :name, class: "field__label" %>
    <%= f.text_field :name, class: "field__control", placeholder: "Ada Lovelace", required: true %>
  </div>

  <div class="field">
    <%= f.label :email, class: "field__label" %>
    <%= f.email_field :email, class: "field__control", placeholder: "ada@example.com", required: true %>
    <p class="field__hint u-text-muted">How we recognise this customer's inbound support mail.</p>
  </div>

  <div class="field">
    <%= f.label :company, class: "field__label" %>
    <%= f.text_field :company, class: "field__control", placeholder: "Analytical Engines Ltd." %>
  </div>

  <div class="field">
    <%= f.label :notes, class: "field__label" %>
    <%= f.text_area :notes, class: "field__control", rows: 4 %>
  </div>

  <div class="u-cluster">
    <%= f.submit customer.persisted? ? "Save changes" : "Add this customer", class: "button button--primary" %>
    <%= link_to "Never mind", (customer.persisted? ? customer_path(customer) : customers_path), class: "button" %>
  </div>
<% end %>
