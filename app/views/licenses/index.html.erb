<% content_for :title, "Licenses — Covenant" %>

<%= render "shared/canvas_head", crumbs: [["Licenses", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">Licenses</h1>
  <div class="perma-header__content">
    <nav class="perma-header__toolbar" aria-label="Actions">
      <%= link_to new_license_path, class: "button button--primary button--small" do %>
        <%= inline_svg_tag "lucide/plus.svg", class: "lucide", size: "16px" %> New license
      <% end %>
    </nav>
  </div>
</header>

<% if @licenses.any? %>
  <ul class="list">
    <% @licenses.each do |license| %>
      <li class="list__item">
        <%= link_to license_path(license.record), class: "list__body" do %>
          <span class="list__titlerow">
            <span class="list__title"><%= license.product %></span>
            <span class="status-pill status-pill--<%= license.status %>"><%= license.status %></span>
          </span>
          <span class="list__meta">
            <span class="list__byline"><%= license.license_key %></span>
            <%= license.customer.display_name %> · <%= pluralize(license.seats, "seat") %>
          </span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty">
    <span class="empty__icon"><%= inline_svg_tag "lucide/key.svg", class: "lucide", size: "40px" %></span>
    <p class="empty__title">No licenses yet</p>
    <p class="empty__text">Issue a license and it will show up here.</p>
    <div class="empty__actions"><%= link_to "New license", new_license_path, class: "button button--primary" %></div>
  </div>
<% end %>
