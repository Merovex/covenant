<% content_for :title, "#{@ticket.title} — Covenant" %>
<% replies = @ticket.replies %>

<%# Agent status actions, pulled out into the canvas head where "Edit" used to
    live — there is NO edit here: the customer's email is never editable.
    "Pending" is set automatically on reply; "Closed" a week after resolved
    (Ticket::CloseResolvedJob). So the manual controls are just these. %>
<% ticket_actions = capture do %>
  <% unless @ticket.resolved? || @ticket.closed? %>
    <%= button_to "Resolved", ticket_path(@record), method: :patch, params: { ticket: { status: :resolved } },
          class: "button button--primary canvas__head-action", form_class: "canvas__head-form" %>
  <% end %>
  <% unless @ticket.on_hold? || @ticket.resolved? || @ticket.closed? %>
    <%= button_to "Hold", ticket_path(@record), method: :patch, params: { ticket: { status: :on_hold } },
          class: "button button--danger canvas__head-action", form_class: "canvas__head-form" %>
  <% end %>
  <% if @ticket.on_hold? || @ticket.resolved? || @ticket.closed? %>
    <%= button_to "Reopen", ticket_path(@record), method: :patch, params: { ticket: { status: :open } },
          class: "button button--ghost canvas__head-action", form_class: "canvas__head-form" %>
  <% end %>
<% end %>

<%= render "shared/canvas_head", crumbs: [["Tickets", tickets_path], [@ticket.title, nil]], lead: ticket_actions do %>
  <%= button_to "Move to trash", ticket_path(@record), method: :delete, class: "menu__item", role: "menuitem",
        form: { data: { turbo_confirm: "Move this ticket to trash?" } } %>
<% end %>

<header class="perma-header">
  <h1 class="perma-header__title"><%= @ticket.title %></h1>
  <p class="perma-header__content u-text-muted">
    <span class="status-pill status-pill--<%= @ticket.status %>"><%= @ticket.status.humanize %></span>
    · <%= link_to @ticket.customer.display_name, customer_path(@ticket.customer) %>
    <% if @ticket.from_address.present? %> · <%= @ticket.from_address %><% end %>
  </p>
</header>

<%# The opener — the customer's first message (or the agent's, if opened in-app). %>
<article class="ticket__opener u-flow"><%= @ticket.content %></article>

<section class="comments" aria-label="Replies">
  <% if replies.any? %>
    <h2 class="comments__heading"><%= pluralize(replies.size, "reply") %></h2>
  <% end %>
  <div class="list">
    <%= render partial: "tickets/reply", collection: replies, as: :reply %>
    <%= render "tickets/replies/form", record: @record %>
  </div>
</section>
