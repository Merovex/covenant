<%# locals: (ticket:, url:) %>
<%= render "shared/error_summary", model: ticket %>

<%= form_with model: ticket, url: url, class: "composer" do |f| %>
  <%# Typeahead customer picker: a native <datalist> filters by name as you type;
      the picked name resolves to customer_id in the hidden field (JS controller). %>
  <div data-controller="customer-picker">
    <input type="text" list="customer-options" class="field__control"
           placeholder="Pick a customer…" aria-label="Customer" autocomplete="off"
           value="<%= ticket.customer&.display_name %>"
           data-customer-picker-target="input"
           data-action="input->customer-picker#resolve change->customer-picker#resolve">
    <datalist id="customer-options" data-customer-picker-target="list">
      <% Customer.order(:name).each do |c| %>
        <option value="<%= c.display_name %>" data-id="<%= c.id %>"></option>
      <% end %>
    </datalist>
    <%= f.hidden_field :customer_id, data: { customer_picker_target: "hidden" } %>
  </div>

  <%= f.text_field :title, class: "composer__title", placeholder: "What's the issue?",
        "aria-label": "Title", required: true, autofocus: true %>

  <%# The opener is the customer's original message — immutable. Writable only
      when opening a ticket in-app (a new record); never on edit. %>
  <% if ticket.record_id.blank? %>
    <%= f.rich_textarea :content, placeholder: "Describe the ticket…", "aria-label": "Opening message" %>
  <% end %>

  <div class="u-cluster">
    <%= f.submit ticket.record_id ? "Save changes" : "Open ticket", class: "button button--primary" %>
    <%= link_to "Never mind", (ticket.record_id ? ticket_path(ticket.record) : tickets_path), class: "button" %>
  </div>
<% end %>
