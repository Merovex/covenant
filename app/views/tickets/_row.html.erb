<%# locals: (ticket:, reply_count: 0) %>
<%# One ticket row for a .list — shared by the tickets index and the dashboard. %>
<li class="list__item">
  <%= link_to ticket_path(ticket.record), class: "list__body" do %>
    <span class="list__titlerow">
      <span class="list__title"><%= ticket.title %></span>
      <span class="status-pill status-pill--<%= ticket.status %>"><%= ticket.status.humanize %></span>
    </span>
    <span class="list__meta">
      <span class="list__byline"><%= ticket.customer.display_name %></span>
      <%= ticket.content.to_plain_text.to_s.truncate(120) %>
    </span>
  <% end %>
  <% if reply_count.to_i.positive? %>
    <span class="list__count" aria-label="<%= reply_count %> replies"><%= reply_count %></span>
  <% end %>
</li>
